{
  "name": "officepulse-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "simulator",
    "discord-bot"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w backend && npm run build -w frontend && npm run build -w simulator && npm run build -w discord-bot",
    "seed": "npm run seed -w backend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:simulator": "npm run dev -w simulator",
    "dev:discord-bot": "npm run dev -w discord-bot"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
