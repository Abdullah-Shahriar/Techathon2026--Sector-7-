{
  "name": "officepulse-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OfficePulse AI fake ESP32 room-node simulator.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dry": "tsx src/index.ts --dry-run",
    "mock-backend": "tsx src/mockBackend.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
