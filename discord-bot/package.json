    "commands:register": "tsx src/commands/registerCommands.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
