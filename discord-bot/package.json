{
  "name": "officepulse-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OfficePulse AI Discord bot with backend data and Gemini humanization.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
